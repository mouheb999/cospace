# Supabase Configuration (PUBLIC - exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin Secret Code (SERVER-ONLY - never expose to client)
# IMPORTANT: Change this to a secure random string in production!
# Generate with: openssl rand -base64 32
ADMIN_SECRET_CODE=change_this_to_a_secure_random_string

# Web Push VAPID Keys (PUBLIC key exposed to browser, PRIVATE is server-only)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
